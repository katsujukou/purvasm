# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "Purvasm is an experimental VM which executes PureScript"
depends: [
  "ocaml" {>= "5.3"}
  "dune" {>= "3.20"}
  "cmdliner"
  "base"
  "yojson"
  "alcotest" {with-test & >= "1.0"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
x-maintenance-intent: ["(latest)"]
