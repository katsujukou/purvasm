{"builtWith":"0.15.16","comments":[{"LineComment":" | Standard-stream IO — the host-system rung (ADR-0068), a sibling of `purvasm-fs` /"},{"LineComment":" | `purvasm-system`. Two total line writers to the standard streams; each appends a newline, so this"},{"LineComment":" | is the generic capability `Effect.Console` is a `ulib` shadow over (`log`/`info`/`debug` →"},{"LineComment":" | `writeLine`, `warn`/`error` → `writeErrLine`). The runtime knows only these generic leaves, not a"},{"LineComment":" | JS-derived `Console.log` name. First-order leaves wrapped in a safe `Effect` API (ADR-0020/0036);"},{"LineComment":" | on purvasm boot binds each leaf to a host leaf, the `.js` is the Node impl for the dual-target"},{"LineComment":" | (ADR-0038)."}],"decls":[{"annotation":{"meta":null,"sourceSpan":{"end":[21,35],"start":[21,1]}},"bindType":"NonRec","expression":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[22,26],"start":[22,13]}},"type":"Var","value":{"identifier":"writeLineImpl","moduleName":["Purvasm","Stdio"]}},"identifier":"writeLine"},{"annotation":{"meta":null,"sourceSpan":{"end":[25,38],"start":[25,1]}},"bindType":"NonRec","expression":{"annotation":{"meta":{"metaType":"IsForeign"},"sourceSpan":{"end":[26,32],"start":[26,16]}},"type":"Var","value":{"identifier":"writeErrLineImpl","moduleName":["Purvasm","Stdio"]}},"identifier":"writeErrLine"}],"exports":["writeLine","writeErrLine"],"foreign":["writeLineImpl","writeErrLineImpl"],"imports":[{"annotation":{"meta":null,"sourceSpan":{"end":[13,24],"start":[13,1]}},"moduleName":["Data","Unit"]},{"annotation":{"meta":null,"sourceSpan":{"end":[14,23],"start":[14,1]}},"moduleName":["Effect"]},{"annotation":{"meta":null,"sourceSpan":{"end":[26,32],"start":[8,1]}},"moduleName":["Prim"]},{"annotation":{"meta":null,"sourceSpan":{"end":[26,32],"start":[8,1]}},"moduleName":["Purvasm","Stdio"]}],"moduleName":["Purvasm","Stdio"],"modulePath":"packages/purvasm-stdio/src/Purvasm/Stdio.purs","reExports":{},"s